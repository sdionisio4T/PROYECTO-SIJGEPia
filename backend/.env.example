@"
# ─────────────────────────────────────────
# SIGJEP - Variables de entorno
# Copia este archivo, renombralo a .env
# y llena los valores con tus datos
# ─────────────────────────────────────────

# Base de datos MySQL local
# Instala MySQL Workbench y crea la BD sigjep_db
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=        # tu contraseña de MySQL Workbench
MYSQL_DB=sigjep_db     # nombre de la base de datos

# Google Gemini IA
# Obtener en: https://aistudio.google.com
# Usar el correo: sigjep.sena@gmail.com
GEMINI_API_KEY=

# Clave para firmar tokens JWT del login
# Pidela al lider del proyecto por WhatsApp
SECRET_KEY=
"@ | Out-File -FilePath .env.example -Encoding utf8